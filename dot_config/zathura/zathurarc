
# Cliboard
# Disable the low-quality intermediate render
# Force immediate full-quality render — no blurry placeholder
# Increase render threads so the sharp version arrives faster
# Keep scroll step small — large steps trigger the blur more aggressively  
# Larger cache so already-seen pages never re-render
# One page per row by default
# Open document in fit-width mode by default
# See man `man zathurarc'
# zathurarc-dark
#stop at page boundries
#zoom settings
Zathura configuration file
map [fullscreen] f toggle_fullscreen
map b toggle_statusbar
map f toggle_fullscreen
set adjust-open "best-fit"
set completion-bg "#303030" #02
set completion-fg "#E0E0E0" #0C
set completion-highlight-bg "#0099c9" #0C
set completion-highlight-fg "#151515" #02
set default-bg "#000000" #00
set default-fg "#FFFFFF" #01
set fast-scroll-interval 0
set font "inconsolata 15"
set guioptions "none"
set highlight-active-color "rgba(0,150, 200, 0.5)"
set highlight-color        "rgba(0,150, 200, 0.3)"
set inputbar-bg "#151515" #00 currently not used
set inputbar-fg "#FFFFFF" #02
set notification-bg "#0079A9" #0B
set notification-error-bg "#AC4142" #08
set notification-error-fg "#151515" #00
set notification-fg "#101010" #00
set notification-warning-bg "#AC4142" #08
set notification-warning-fg "#151515" #00
set page-cache-size 15
set page-cache-size 20
set pages-per-row 1
set recolor "true"
set recolor-darkcolor "#EFEFEF" #06
set recolor-keephue "false"
set recolor-keephue "true"
set recolor-lightcolor "#000000" #00
set recolor-reverse-video "true"
set render-loading "false"
set render-loading-bg "#000000" #00
set render-loading-fg "#000000" #01
set scroll-full-overlap 0.01
set scroll-page-aware "true"
set scroll-step 30
set scroll-step 50
set selection-clipboard clipboard
set smooth-scroll "true"
set statusbar-bg "#202020" #01
set statusbar-fg "#B0B0B0" #04
set zoom-min 10
unmap f
