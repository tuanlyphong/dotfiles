#!/usr/bin/env bash

set -euo pipefail

MODE="${1:-region}"

case "${MODE}" in
region)
  grim -g "$(slurp -d)" -
  ;;
window)
  niri msg action screenshot-window
  sleep 0.5
  wl-paste --type image/png
  ;;
monitor-focused)
  grim -o "$(niri msg --json focused-output | jq -r .name)" -
  ;;
monitor-all)
  grim -
  ;;
*)
  echo "'${MODE}' is not supported!" >&2
  exit 1
  ;;
esac |
  tee >(wl-copy --type image/png) |
  satty \
    --filename - \
    --output-filename "$HOME/Pictures/Screenshots/screenshot-%+.png"
