#!/bin/sh

music_dir="$HOME/Music"
previewdir="$XDG_CONFIG_HOME/ncmpcpp/previews"
filename="$(mpc --format "$music_dir"/%file% current)"
previewname="$previewdir/$(mpc --format %album% current | base64).png"

# Find a .jpg cover in the song's directory or its parent (for cue splits)
songdir="$(dirname "$filename")"
coverjpg="$(find "$songdir" -maxdepth 1 -type f -iname '*.jpg' | head -n 1)"

if [ -z "$coverjpg" ]; then
  parentdir="$(dirname "$songdir")"
  coverjpg="$(find "$parentdir" -maxdepth 1 -type f -iname '*.jpg' | head -n 1)"
fi

[ -e "$previewname" ] || ffmpeg -y -i "$filename" -an -vf scale=128:128 "$previewname" >/dev/null 2>&1

# Use .jpg cover if found, otherwise fallback to preview
if [ -n "$coverjpg" ]; then
  icon="$coverjpg"
else
  icon="$previewname"
fi

notify-send -r 27072 "Now Playing" "$(mpc --format '%title% \n%artist% - %album%' current)" -i "$icon"
